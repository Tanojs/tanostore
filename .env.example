# === SUPABASE ===
# Ambil di: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=isi-dengan-anon-public-key

# PENTING: Service Role Key bersifat RAHASIA, jangan pernah diawali NEXT_PUBLIC_
# dan jangan pernah dikirim/dipakai di sisi browser. Hanya dipakai di
# app/api/pakasir-webhook/route.ts (server).
SUPABASE_SERVICE_ROLE_KEY=isi-dengan-service-role-key

# === PAKASIR (payment gateway) ===
# Ambil di dashboard project Pakasir kamu
PAKASIR_PROJECT=isi-dengan-slug-project-pakasir
PAKASIR_API_KEY=isi-dengan-api-key-pakasir
